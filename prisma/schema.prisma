datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String
  status      String   // Idea, Building, Shipped, Paused
  liveUrl     String?
  repoLink    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  entries     Entry[]
  resources   Resource[]
  tags        Tag[]    @relation("ProjectTags")
}

model Entry {
  id          String   @id @default(cuid())
  title       String
  date        DateTime @default(now())
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String?
  resources   Resource[]
  tags        Tag[]    @relation("EntryTags")
}

model Resource {
  id          String   @id @default(cuid())
  url         String
  title       String
  category    String   // Article, Video, Docs, Course, Other
  notes       String?
  isRead      Boolean  @default(false)
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  entry       Entry?   @relation(fields: [entryId], references: [id], onDelete: SetNull)
  entryId     String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?
  tags        Tag[]    @relation("ResourceTags")
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  entries   Entry[]   @relation("EntryTags")
  projects  Project[] @relation("ProjectTags")
  resources Resource[] @relation("ResourceTags")
}
